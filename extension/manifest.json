{
  "manifest_version": 3,
  "name": "TMDB to Infuse",
  "version": "1.0.1",
  "description": "Seamlessly open TMDB movies and shows in Infuse.",
  "permissions": [
    "contextMenus",
    "tabs"
  ],
  "host_permissions": [
    "https://www.themoviedb.org/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.themoviedb.org/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "styles.css"
      ]
    }
  ],
  "icons": {
    "16": "icons/infuse.png",
    "32": "icons/infuse.png",
    "48": "icons/infuse.png",
    "128": "icons/infuse.png"
  },
  "web_accessible_resources": [
    {
      "resources": [
        "icons/infuse.png"
      ],
      "matches": [
        "https://www.themoviedb.org/*"
      ]
    }
  ],
  "action": {
    "default_title": "TMDB to Infuse"
  }
}